Host *
  AddKeysToAgent yes
  UseKeychain yes
  IdentitiesOnly yes

  ServerAliveInterval 60
  ServerAliveCountMax 3
  ConnectTimeout 10

  StrictHostKeyChecking ask
  HashKnownHosts yes
  UpdateHostKeys yes

  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519

Host codeberg.org
  HostName codeberg.org
  User git
  IdentityFile ~/.ssh/id_ed25519

Host tangled.org
  HostName tangled.org
  User git
  IdentityFile ~/.ssh/id_ed25519
  AddressFamily inet
