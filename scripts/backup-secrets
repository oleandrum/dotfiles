#!/bin/zsh

# Export recovery material without ever placing it in the dotfiles repository.
emulate -L zsh
setopt err_exit no_unset pipe_fail
umask 077

script_name="${0:t}"
output_dir="$HOME/Desktop"
dry_run=false

usage() {
  print "Usage: $script_name [--output DIRECTORY] [--dry-run]"
  print 'Creates a passphrase-encrypted SSH, GPG and Git-identity recovery archive.'
}

while (( $# > 0 )); do
  case "$1" in
    --output)
      (( $# >= 2 )) || { print -u2 '--output requires a directory.'; exit 2; }
      output_dir="$2"
      shift 2
      ;;
    --dry-run) dry_run=true; shift ;;
    --help|-h) usage; exit 0 ;;
    *) print -u2 "Unknown option: $1"; usage; exit 2 ;;
  esac
done

(( $+commands[gpg] )) || { print -u2 'gpg is required to encrypt the archive.'; exit 1; }

timestamp="$(date +%Y%m%d-%H%M%S)"
archive="$output_dir/dotfiles-secrets-$timestamp.tar.gz.gpg"

if $dry_run; then
  print "would create encrypted archive: $archive"
  print 'would include: SSH identity files, GPG secret/public keys and ownertrust, ~/.gitconfig.local'
  print 'would prompt for an encryption passphrase; no files would be written during dry-run.'
  exit 0
fi

mkdir -p "$output_dir"
temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/dotfiles-secrets.XXXXXX")"
trap 'rm -rf -- "$temp_dir"' EXIT INT TERM
mkdir -p "$temp_dir/ssh" "$temp_dir/gpg" "$temp_dir/git"

for file in "$HOME"/.ssh/id_*(N); do
  [[ -f "$file" ]] && cp -p "$file" "$temp_dir/ssh/"
done
[[ -f "$HOME/.ssh/config" ]] && cp -p "$HOME/.ssh/config" "$temp_dir/ssh/"
[[ -f "$HOME/.gitconfig.local" ]] && cp -p "$HOME/.gitconfig.local" "$temp_dir/git/"

if gpg --list-secret-keys --with-colons 2>/dev/null | command grep -q '^sec:'; then
  gpg --armor --export-secret-keys > "$temp_dir/gpg/secret-keys.asc"
  gpg --armor --export > "$temp_dir/gpg/public-keys.asc"
  gpg --export-ownertrust > "$temp_dir/gpg/ownertrust.txt"
else
  print -u2 'No GPG secret keys found; continuing with SSH and Git identity only.'
fi

print -r -- 'Recovery archive contents:' > "$temp_dir/README.txt"
print -r -- '- ssh/: SSH identity files and config' >> "$temp_dir/README.txt"
print -r -- '- gpg/: secret/public key exports and ownertrust' >> "$temp_dir/README.txt"
print -r -- '- git/: local Git identity configuration' >> "$temp_dir/README.txt"
print -r -- '' >> "$temp_dir/README.txt"
print -r -- 'To inspect after decrypting: gpg --decrypt ARCHIVE | tar -tzf -' >> "$temp_dir/README.txt"
print -r -- 'Import GPG keys before restoring Git signing configuration.' >> "$temp_dir/README.txt"

tar_file="$temp_dir/recovery.tar.gz"
tar -C "$temp_dir" -czf "$tar_file" ssh gpg git README.txt
gpg --symmetric --cipher-algo AES256 --output "$archive" "$tar_file"
chmod 600 "$archive"

print "Created encrypted recovery archive: $archive"
print 'Move it to an encrypted external drive or secure password-manager attachment; do not leave it on the Desktop.'
