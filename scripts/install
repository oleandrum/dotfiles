#!/bin/zsh

emulate -L zsh
setopt err_exit no_unset pipe_fail

script_dir="${0:A:h}"
repo_root="${script_dir:h}"
script_name="${0:t}"
dry_run=false
sync_args=()

usage() {
  print "Usage: $script_name [--dry-run] [--force]"
  print "Creates local directories, installs Deno/NVM/Node LTS, then runs sync."
}

for arg in "$@"; do
  case "$arg" in
    --dry-run) dry_run=true; sync_args+=(--dry-run) ;;
    --force) sync_args+=(--force) ;;
    --help|-h) usage; exit 0 ;;
    *) print -u2 "Unknown option: $arg"; usage; exit 2 ;;
  esac
done

if [[ "$(uname)" != Darwin ]]; then
  print -u2 "This setup targets macOS. No changes were made."
  exit 1
fi

if $dry_run; then
  print "create: ~/.ssh and ~/.gnupg"
  [[ -e "$HOME/.gitconfig.local" ]] || print "create: ~/.gitconfig.local from template"
else
  mkdir -p "$HOME/.ssh" "$HOME/.gnupg"
  chmod 700 "$HOME/.ssh" "$HOME/.gnupg"
  if [[ ! -e "$HOME/.gitconfig.local" ]]; then
    cp "$repo_root/templates/.gitconfig.local.example" "$HOME/.gitconfig.local"
    chmod 600 "$HOME/.gitconfig.local"
    print "created: ~/.gitconfig.local (fill in your identity before signing commits)"
  fi
fi

"$script_dir/sync" "${sync_args[@]}"

if $dry_run; then
  [[ -x "$HOME/.deno/bin/deno" ]] || print 'install: Deno from https://deno.land/install.sh'
  [[ -s "$HOME/.nvm/nvm.sh" ]] || print 'install: NVM v0.40.5 from nvm-sh/nvm'
  print 'install: current Node LTS through NVM'
else
  if [[ ! -x "$HOME/.deno/bin/deno" ]]; then
    curl -fsSL https://deno.land/install.sh | sh
  fi

  if [[ ! -s "$HOME/.nvm/nvm.sh" ]]; then
    PROFILE=/dev/null bash -c 'curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.5/install.sh | bash'
  fi

  export NVM_DIR="$HOME/.nvm"
  source "$NVM_DIR/nvm.sh"
  nvm install --lts --latest-npm
  nvm alias default 'lts/*'
fi

if ! $dry_run; then
  print "Import the Terminal profile from: $repo_root/config/terminal/Flexoki Light.terminal"

  fonts_dir="$repo_root/fonts"
  if [[ -d "$fonts_dir" ]]; then
    while IFS= read -r -d '' font; do
      mkdir -p "$HOME/Library/Fonts"
      cp -f "$font" "$HOME/Library/Fonts/"
      print "installed font: ${font:t}"
    done < <(find "$fonts_dir" -type f \( -iname '*.otf' -o -iname '*.ttf' -o -iname '*.ttc' \) -print0)
  fi

  extensions_file="$repo_root/config/vscode/extensions.txt"
  if (( $+commands[code] )) && [[ -f "$extensions_file" ]]; then
    while IFS= read -r extension; do
      [[ -z "$extension" || "$extension" == \#* ]] && continue
      code --install-extension "$extension"
    done < "$extensions_file"
  elif [[ -f "$extensions_file" ]]; then
    print "VS Code extensions: install Visual Studio Code, enable its 'code' command, then rerun install."
  fi
fi
