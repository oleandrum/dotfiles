* text=auto

# LaTeX and academic writing
*.bib text diff=bibtex
*.bibtex text diff=bibtex
*.cls text diff=tex
*.sty text diff=tex
*.tex text diff=tex
*.pdf diff=astextplain

# Documents
*.csv text
*.doc diff=astextplain
*.docx diff=astextplain
*.epub diff=astextplain
*.md text diff=markdown
*.txt text

# Binary assets
*.otf binary
*.ttf binary
*.woff binary
*.woff2 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tif binary
*.tiff binary
*.ico binary
*.eps binary
*.tec binary

# Scripts and serialised data
*.bash text eol=lf
*.fish text eol=lf
*.sh text eol=lf
*.zsh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
*.json text
*.toml text
*.xml text
*.yaml text
*.yml text

# Archives and patches
*.7z binary
*.gz binary
*.tar binary
*.tgz binary
*.zip binary
*.patch -text

# Do not include repository internals in source archives.
.editorconfig export-ignore
.gitattributes export-ignore
.github export-ignore
.gitignore export-ignore
.gitkeep export-ignore
